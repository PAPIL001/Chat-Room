# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── MongoDB ──────────────────────────────────────────
# Local:  mongodb://localhost:27017/chatterup
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/chatterup
MONGO_URI=mongodb://localhost:27017/chatterup

# ─── CORS (optional – comma-separated allowed origins) ─
# ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
